body, header, nav, main, footer, h1, div, img {
	margin: 0;
	padding: 0;
	border: 0;
}

body {
	background-color: #ebe6e6;
	font-size: 1.15em;
}

img {
	max-width: 100%;
	display: block;
	border-radius: 7px;
}

* {
	box-sizing: border-box;
}

header {
	top: 0;
}

/*Mobile rules*/
.mobile {
	display: block;
}
	
.tablet-desktop {
	display: none;
}

nav {
	padding: 1%;
	margin-bottom: 1%;
}
	
nav ul {
	list-style-type: none;
	text-align: center;
}
	
nav li {
	border-top: 1px solid #267318;
	width: 100%;
	font-size: 1.75em;
}
	
nav li a {
	display: block;
	padding: 0.5em 1em;
	text-decoration: none;
	color: #394381;
}

main {
	padding: 2%;
}

main h2 {
	text-align: center;
	color: #353f70;
	border-radius: 5px;
	border-top: 1px solid #000;
	border-bottom: 1px solid #000;
	border-width: 50%
}

main h3 {
	font-weight: bold;
	font-size: 1.75em;
}

ul {
	list-style-type: square;
}
	
table {
	border: 1px solid #000;
	border-collapse: collapse;
	margin: auto;
	padding: 2%;
	font-size: 0.75em;
}

td {
	border: 1px solid #000;
	padding: 2%;
	width: 50%;
}


@media screen and (min-width: 769px),print {
	
	.mobile {
		display: none;
	}
	
	.tablet-desktop {
		display: block;
	}
	
	.grid {
		display: grid;
		grid-template-columns: auto auto;
		grid-gap: 10px;
	}
	
	nav li a:hover {
		color: #fff;
		border: 3px solid white; 
	}
	
	table {
		width: 90%;
		font-size: 1.15em;
	}
	td img {
		width: 50%;
	}

	#education {
		font-size: 1.25em;
	}

	#education img {
		float: right;
	}
	
	#eduinfo {
		padding: 2%;
	}
	
	#empinfo {
		float: left;
		font-size: 1.25em;
	}
	
	#pics {
		float: right;
		margin: auto;
	}
	
	#youtube {
		margin-right: auto;
		margin-left: auto;
		text-align: center;
	}
	
}